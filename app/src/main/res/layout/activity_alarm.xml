<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp">

        <TextView
            android:id="@+id/tvClock"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:textColor="@color/white"
            android:textSize="64sp"
            android:textStyle="bold"
            tools:text="08:00"
            xmlns:tools="http://schemas.android.com/tools" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/say_your_manifest"
            android:textColor="@color/white_70"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvManifest"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="#1AFFFFFF"
            android:gravity="center"
            android:padding="20dp"
            android:textColor="@color/sun"
            android:textSize="24sp"
            android:textStyle="bold"
            android:lineSpacingExtra="6dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSpeak"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="32dp"
            android:text="@string/btn_speak"
            android:textSize="20sp"
            app:backgroundTint="@color/sun"
            android:textColor="@color/night_deep"
            xmlns:app="http://schemas.android.com/apk/res-auto" />

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:textColor="@color/white"
            android:textSize="17sp" />

        <TextView
            android:id="@+id/tvHeard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textColor="@color/white_70"
            android:textSize="15sp"
            android:fontFamily="sans-serif-light" />

        <LinearLayout
            android:id="@+id/groupTyping"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/type_fallback_hint"
                android:textColor="@color/white_70"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etTyped"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:textColor="@color/white"
                android:textColorHint="@color/white_70"
                android:backgroundTint="@color/sun"
                android:importantForAutofill="no" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnTypeConfirm"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/confirm"
                android:textColor="@color/sun" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
